# Настройки для подключения к почтовому серверу
# Скопируйте этот файл в .env и заполните своими данными

# IMAP настройки (для чтения писем)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# SMTP настройки (для отправки писем)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Ваш email адрес и пароль
# Для Gmail используйте App Password (не обычный пароль!)
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Адрес для пересылки писем
FORWARD_TO=forward_to@example.com

# Использовать TLS (true для порта 587, false для порта 465)
USE_TLS=true

# Автозапуск email forwarder при старте Django (true/false)
AUTO_START_EMAIL_FORWARDER=true

# Порт Django dev-сервера (manage.py runserver)
DJANGO_PORT=8888

# ============================================
# Настройки логирования
# ============================================

# Запись в файл и/или консоль (true/false)
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# Путь к файлу лога (относительно корня проекта)
LOG_FILE=logs/django.log

# Уровни логирования: DEBUG, INFO, WARNING, ERROR
DJANGO_LOG_LEVEL=INFO
API_LOG_LEVEL=INFO
FORWARDER_LOG_LEVEL=INFO
COURSES_LOG_LEVEL=INFO

# ============================================
# Примеры конфигурации для других сервисов:
# ============================================

# Yandex Mail:
# IMAP_SERVER=imap.yandex.ru
# IMAP_PORT=993
# SMTP_SERVER=smtp.yandex.ru
# SMTP_PORT=465
# USE_TLS=false

# Mail.ru:
# IMAP_SERVER=imap.mail.ru
# IMAP_PORT=993
# SMTP_SERVER=smtp.mail.ru
# SMTP_PORT=465
# USE_TLS=false

# Outlook/Hotmail:
# IMAP_SERVER=outlook.office365.com
# IMAP_PORT=993
# SMTP_SERVER=smtp.office365.com
# SMTP_PORT=587
# USE_TLS=true